# Bounty Hunter - Environment Configuration
# Copy this file to .env and fill in your values.

# --- LLM API (Required) ---
# Any OpenAI-compatible endpoint: Ollama, LiteLLM, OpenRouter, vLLM, Hermes Gateway, etc.
LLM_API_URL=http://127.0.0.1:11434
LLM_API_KEY=

# Default model for AI features (analyze, copilot, checklist, draft generation)
LLM_DEFAULT_MODEL=gpt-4o-mini

# --- Optional: Secondary Router ---
# For multi-provider setups (e.g. 9Router, LiteLLM proxy).
# Models containing "/" (e.g. "anthropic/claude-sonnet") are routed here.
# Leave empty if you only use one endpoint.
LLM_ROUTER_URL=
LLM_ROUTER_KEY=

# --- Server ---
PORT=3333
